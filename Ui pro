-- === ฟังก์ชันสร้างปุ่ม ===
local function CreateButton(txt, color, callback, subCallback)
    local Container = Instance.new("Frame", Scroll)
    Container.Size = UDim2.new(0.9, 0, 0, 45)
    Container.BackgroundTransparency = 1

    local MainBtn = Instance.new("TextButton", Container)
    MainBtn.Size = UDim2.new(0.78, 0, 1, 0)
    MainBtn.Text = txt
    MainBtn.BackgroundColor3 = color
    MainBtn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", MainBtn)
    MainBtn.MouseButton1Click:Connect(callback)

    if subCallback then
        local SubBtn = Instance.new("TextButton", Container)
        SubBtn.Size = UDim2.new(0.18, 0, 1, 0)
        SubBtn.Position = UDim2.new(0.82, 0, 0, 0)
        SubBtn.Text = "⚙️"
        SubBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        SubBtn.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", SubBtn)
        SubBtn.MouseButton1Click:Connect(subCallback)
    end
    
    Scroll.CanvasSize = UDim2.new(0, 0, 0, UIList.AbsoluteContentSize.Y + 20)
end

-- 1. Fly Mode (ปรับปรุงใหม่)
CreateButton("FLY MODE", Color3.fromRGB(0, 102, 204), function()
    Flying = not Flying
    local char = LP.Character
    local hrp = char:WaitForChild("HumanoidRootPart")
    
    if Flying then
        local bg = Instance.new("BodyGyro", hrp)
        bg.P = 9e4
        bg.maxTorque = Vector3.new(9e9, 9e9, 9e9)
        bg.cframe = hrp.CFrame
        
        local bv = Instance.new("BodyVelocity", hrp)
        bv.velocity = Vector3.new(0, 0.1, 0)
        bv.maxForce = Vector3.new(9e9, 9e9, 9e9)
        
        task.spawn(function()
            while Flying do
                local cam = workspace.CurrentCamera
                local moveDir = char.Humanoid.MoveDirection
                
                -- บินตามทิศทางการหันหน้าจอ
                if moveDir.Magnitude > 0 then
                    bv.velocity = cam.CFrame.LookVector * FlySpeed
                else
                    bv.velocity = Vector3.new(0, 0.1, 0)
                end
                bg.cframe = cam.CFrame
                RunService.RenderStepped:Wait()
            end
            bg:Destroy()
            bv:Destroy()
        end)
    end
end, function()
    if FlySpeed < 300 then FlySpeed = FlySpeed + 50 else FlySpeed = 50 end
    print("Fly Speed: "..FlySpeed)
end)

-- 2. Slide Mode (พุ่งตามทิศทาง)
CreateButton("SLIDE MODE", Color3.fromRGB(0, 150, 100), function()
    Sliding = not Sliding
    task.spawn(function()
        while Sliding do
            local char = LP.Character
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChild("Humanoid")
            if hrp and hum then
                local moveDir = hum.MoveDirection
                if moveDir.Magnitude > 0 then
                    hrp.Velocity = Vector3.new(moveDir.X * SlideSpeed, hrp.Velocity.Y, moveDir.Z * SlideSpeed)
                else
                    hrp.Velocity = Vector3.new(hrp.CFrame.LookVector.X * SlideSpeed, hrp.Velocity.Y, hrp.CFrame.LookVector.Z * SlideSpeed)
                end
            end
            RunService.RenderStepped:Wait()
        end
    end)
end, function()
    if SlideSpeed < 250 then SlideSpeed = SlideSpeed + 50 else SlideSpeed = 50 end
    print("Slide Speed: "..SlideSpeed)
end)

-- 3. Smooth Spider
CreateButton("SMOOTH SPIDER", Color3.fromRGB(150, 0, 0), function()
    if TargetPos then
        task.spawn(function()
            for i = 0, 1, 0.05 do
                if not LP.Character or not LP.Character:FindFirstChild("HumanoidRootPart") then break end
                LP.Character.HumanoidRootPart.CFrame = LP.Character.HumanoidRootPart.CFrame:Lerp(TargetPos, i)
                task.wait(0.01)
            end
        end)
    end
end, function() TargetPos = LP.Character.HumanoidRootPart.CFrame print("Pos Set!") end)

-- 4. Bring All
CreateButton("BRING ALL", Color3.fromRGB(100, 0, 150), function()
    BringingAll = not BringingAll
    task.spawn(function()
        while BringingAll do
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    p.Character.HumanoidRootPart.CFrame = LP.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -3)
                end
            end
            task.wait(0.3)
        end
    end)
end)

