-- === ฟังก์ชันสร้างปุ่มหลัก ===
local function CreateButton(txt, color, callback, subCallback)
    local Container = Instance.new("Frame", Scroll)
    Container.Size = UDim2.new(0.9, 0, 0, 45)
    Container.BackgroundTransparency = 1

    local MainBtn = Instance.new("TextButton", Container)
    MainBtn.Size = UDim2.new(0.78, 0, 1, 0)
    MainBtn.Text = txt
    MainBtn.BackgroundColor3 = color
    MainBtn.TextColor3 = Color3.new(1,1,1)
    MainBtn.Font = Enum.Font.Gotham
    Instance.new("UICorner", MainBtn)
    MainBtn.MouseButton1Click:Connect(callback)

    if subCallback then
        local SubBtn = Instance.new("TextButton", Container)
        SubBtn.Size = UDim2.new(0.18, 0, 1, 0)
        SubBtn.Position = UDim2.new(0.82, 0, 0, 0)
        SubBtn.Text = "⚙️"
        SubBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        SubBtn.TextColor3 = Color3.new(1,1,1)
        Instance.new("UICorner", SubBtn)
        SubBtn.MouseButton1Click:Connect(subCallback)
    end
    
    Scroll.CanvasSize = UDim2.new(0, 0, 0, UIList.AbsoluteContentSize.Y + 20)
    return Container
end

-- 1. Smooth Spiderman
CreateButton("SMOOTH SPIDER", Color3.fromRGB(150, 0, 0), function()
    if TargetPos then
        local char = LP.Character
        task.spawn(function()
            for i = 0, 1, 0.05 do
                if not char or not char:FindFirstChild("HumanoidRootPart") then break end
                char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame:Lerp(TargetPos, i)
                task.wait(0.01)
            end
        end)
    end
end, function() print("Set Target First!") end)

-- 2. Slide Mode (พุ่งไปตามทิศทางที่หัน)
CreateButton("SLIDE MODE", Color3.fromRGB(0, 150, 100), function()
    Sliding = not Sliding
    if Sliding then
        print("Slide: ON (Speed: "..SlideSpeed..")")
        task.spawn(function()
            while Sliding do
                local char = LP.Character
                local hrp = char:FindFirstChild("HumanoidRootPart")
                local hum = char:FindFirstChild("Humanoid")
                
                if hrp and hum then
                    -- คำนวณทิศทางจาก MoveDirection (ถ้ากดเดิน) หรือทิศที่หน้าหัน (LookVector)
                    local moveDir = hum.MoveDirection
                    if moveDir.Magnitude > 0 then
                        hrp.Velocity = Vector3.new(moveDir.X * SlideSpeed, hrp.Velocity.Y, moveDir.Z * SlideSpeed)
                    else
                        -- ถ้าไม่ได้กดเดิน ให้พุ่งไปข้างหน้าตรงๆ
                        local lookDir = hrp.CFrame.LookVector
                        hrp.Velocity = Vector3.new(lookDir.X * SlideSpeed, hrp.Velocity.Y, lookDir.Z * SlideSpeed)
                    end
                end
                RunService.RenderStepped:Wait()
            end
        end)
    else
        print("Slide: OFF")
    end
end, function()
    if SlideSpeed < 200 then SlideSpeed = SlideSpeed + 25 else SlideSpeed = 50 end
    print("Slide Speed set to: "..SlideSpeed)
end)

-- 3. Bring All
CreateButton("BRING ALL", Color3.fromRGB(100, 0, 150), function()
    BringingAll = not BringingAll
    task.spawn(function()
        while BringingAll do
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    p.Character.HumanoidRootPart.CFrame = LP.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -3)
                end
            end
            task.wait(0.3)
        end
    end)
end, function() BringingAll = false end)

