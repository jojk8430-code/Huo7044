-- 7. Player TP (ดึงคนใกล้ที่สุดมา)
CreateButton("Get Nearest Player", Color3.fromRGB(100, 0, 150), Scroll, function()
    local myRoot = LocalPlayer.Character.HumanoidRootPart
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            p.Character.HumanoidRootPart.CFrame = myRoot.CFrame * CFrame.new(0, 0, -5)
            break 
        end
    end
end)

-- 8. Fly Mode (UI แยก)
CreateButton("Open Fly Menu", Color3.fromRGB(50, 50, 50), Scroll, function()
    local FlyGui = Instance.new("Frame", ScreenGui)
    FlyGui.Size = UDim2.new(0, 150, 0, 100)
    FlyGui.Position = UDim2.new(0, 50, 0.5, 0)
    FlyGui.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Instance.new("UICorner", FlyGui)
    
    CreateButton("Fly Toggle", Color3.fromRGB(0, 100, 200), FlyGui, function()
        Flying = not Flying
        local bg = Instance.new("BodyGyro", LocalPlayer.Character.HumanoidRootPart)
        local bv = Instance.new("BodyVelocity", LocalPlayer.Character.HumanoidRootPart)
        bg.P = 9e4 bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9) bg.CFrame = LocalPlayer.Character.HumanoidRootPart.CFrame
        bv.Velocity = Vector3.new(0,0.1,0) bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        task.spawn(function()
            while Flying do
                bv.Velocity = LocalPlayer.Character.Humanoid:GetMoveDirection() * FlySpeed
                task.wait()
            end
            bg:Destroy() bv:Destroy()
        end)
    end)
    
    CreateButton("Close Fly", Color3.fromRGB(100, 0, 0), FlyGui, function() FlyGui:Destroy() Flying = false end)
end)

