-- === ระบบเพิ่ม Script อิสระ (+) ===
local scriptCount = 0
AddScriptBtn.MouseButton1Click:Connect(function()
    scriptCount = scriptCount + 1
    local customCode = "-- ใส่สคริปต์ของคุณที่นี่\nprint('Script "..scriptCount.." Running!')"
    
    CreateButton("CUSTOM SCRIPT "..scriptCount, Color3.fromRGB(80, 80, 80), function()
        -- ฟังก์ชันรันสคริปต์ (ใช้ loadstring สำหรับ Executor ทั่วไป)
        local success, err = pcall(function()
            local func = loadstring(customCode)
            if func then func() else warn("Loadstring not supported or Code Error") end
        end)
        if not success then warn("Error: "..err) end
    end, function()
        print("Edit Script "..scriptCount.." (Feature coming soon)")
    end)
end)
