end)

-- 3. Spiderman Mode (ขยับทีละนิด)
CreateButton("Spiderman Mode", Color3.fromRGB(180, 0, 0), Scroll, function()
    if TargetPos then
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            task.spawn(function()
                for i = 1, 20 do -- แบ่งเป็น 20 ขั้น
                    char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame:Lerp(TargetPos, 0.15)
                    task.wait(0.05)
                end
            end)
        end
    end
end)

