    Range = {0, 24},
    Increment = 0.1,
    CurrentValue = 12,
    Callback = function(V)
        game:GetService("Lighting").ClockTime = V
    end
})

VisualTab:CreateSection("เอฟเฟกต์การมองเห็น")
