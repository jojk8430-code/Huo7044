local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "นางฟ้า hub🪽 V.21 [ULTIMATE TIME]",
   LoadingTitle = "กำลังควบคุมกาลเวลาและจักรวาล...",
   LoadingSubtitle = "Time Control & All Features Added",
   ConfigurationSaving = { Enabled = false }
})

-- [[ ตัวแปรหลัก ]]
local Player = game.Players.LocalPlayer
local Character, Humanoid, Root
local WalkSpeedValue, JumpPowerValue = 16, 50
local GravityValue = 196.2
local Flying, SpiderManEnabled, AutoClickEnabled = false, false, false
local FullBrightEnabled, AntiAFKEnabled = false, false
local currentMap = nil

local function UpdateCharacter()
    Character = Player.Character or Player.CharacterAdded:Wait()
    Humanoid = Character:WaitForChild("Humanoid")
    Root = Character:WaitForChild("HumanoidRootPart")
    Humanoid.UseJumpPower = true 
end
UpdateCharacter()
Player.CharacterAdded:Connect(function() task.wait(0.7) UpdateCharacter() end)

-- [[ TABS ]]
local MainTab = Window:CreateTab("เคลื่อนที่/โน้มถ่วง", 4483362458)
local MapTab = Window:CreateTab("เสกแมพส่วนตัว", 4483362458)
local VisualTab = Window:CreateTab("แสงสี/กาลเวลา", 4483362458) -- อัปเกรดใหม่
local GameTab = Window:CreateTab("มินิเกมดวง", 4483362458)
local AdvTab = Window:CreateTab("ช่วยฟาร์ม/แลค", 4483362458)

-- ### 1. ระบบกาลเวลาและแสงสี (NEW!) ###
