-- 4. ฟังก์ชันสแกนไอเทมที่ถือ + สลับวนลูป (บั๊กเพิ่มจำนวนไอเทม)
ScanBtn.MouseButton1Click:Connect(function()
    if swapRunning then
        swapRunning = false
        ScanBtn.Text = "🔍 สแกนไอเทมในตัว และ สลับถือวนลูป"
        ScanBtn.BackgroundColor3 = Color3.fromRGB(130, 70, 200)
        return
    end
    
    local character = player.Character
    local backpack = player:WaitForChild("Backpack")
    
    -- ค้นหาไอเทมทั้งหมดในกระเป๋าและที่ถืออยู่
    local tools = {}
    for _, t in pairs(backpack:GetChildren()) do if t:IsA("Tool") then table.insert(tools, t) end end
    if character then
        for _, t in pairs(character:GetChildren()) do if t:IsA("Tool") then table.insert(tools, t) end end
    end
    
    if #tools < 1 then
        updateMonitor("❌ ไม่พบไอเทมใดๆ ในตัวผู้เล่น!", "ไม่มี")
        return
    end
    
    swapRunning = true
    ScanBtn.Text = "🔴 หยุดสลับไอเทม"
    ScanBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    
    task.spawn(function()
        while swapRunning do
            for _, tool in pairs(tools) do
                if not swapRunning then break end
                if tool and tool.Parent then
                    -- สลับสวมใส่ไอเทมเข้าตัวละครแบบรวดเร็ว
                    player.Character.Humanoid:EquipTool(tool)
                    totalFired = totalFired + 1
                    updateMonitor("กำลังสลับถือวนลูปไอเทม...", tool.Name)
                    task.wait(tonumber(DelayBox.Text) or 0.1)
                end
            end
        end
    end)
end)

