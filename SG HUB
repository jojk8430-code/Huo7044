-- ฟังก์ชันสร้างเอฟเฟกต์ฟองอากาศลอย (Purple Bubble Background)
local function CreateBubbleBackground(parent)
local BubbleContainer = Instance.new("Frame")
BubbleContainer.Size = UDim2.new(1, 0, 1, 0)
BubbleContainer.BackgroundTransparency = 1
BubbleContainer.ClipsDescendants = true
BubbleContainer.Parent = parent
task.spawn(function()
while parent and parent.Parent do
task.wait(math.random(4, 8) / 10)
if not parent or not parent.Parent then break end
local bubble = Instance.new("Frame")
local size = math.random(8, 25)
bubble.Size = UDim2.new(0, size, 0, size)
bubble.Position = UDim2.new(math.random(0, 100)/100, 0, 1, 10)
bubble.BackgroundColor3 = Color3.fromRGB(180, 70, 255)
bubble.BackgroundTransparency = math.random(5, 8) / 10
local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(1, 0)
UICorner.Parent = bubble
bubble.Parent = BubbleContainer
local duration = math.random(4, 7)
local tweenMove = TweenService:Create(bubble, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
Position = UDim2.new(bubble.Position.X.Scale, math.random(-30, 30), -0.2, 0)
})
local tweenFade = TweenService:Create(bubble, TweenInfo.new(duration * 0.4, Enum.EasingStyle.Linear, Enum.EasingDirection.In, 0, false, duration * 0.6), {
BackgroundTransparency = 1
})
tweenMove:Play()
tweenFade:Play()
task.spawn(function()
tweenMove.Completed:Wait()
bubble:Destroy()
end)
end
end)
end
