local hoverOffset = math.sin(spinTime * 2) * 0.25
VisualPart.CFrame = CFrame.new(spawnPos + Vector3.new(0, hoverOffset, 0)) * CFrame.Angles(0, spinTime * 1.5, math.rad(25))
BaseRing.CFrame = CFrame.new(spawnPos - Vector3.new(0, 1.2, 0)) * CFrame.Angles(0, -spinTime * 0.8, 0)
task.wait(0.03)
end
-- ค่อยๆ จางหายไปเมื่อหมดเวลา
for trans = 0, 1, 0.1 do
