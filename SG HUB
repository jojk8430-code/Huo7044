-- [[ 3. ระบบสร้างฟองลอยน้ำ (Purple Bubble FX) ]] --
local isSpawningBubbles = true

task.spawn(function()
    while isSpawningBubbles do
        task.wait(0.2) -- ปรับเวลาเกิดฟองให้เสถียรขึ้น
        
        local bubble = Instance.new("Frame")
        bubble.Name = "Bubble"
        
        local size = math.random(8, 22)
        bubble.Size = UDim2.new(0, size, 0, size)
        bubble.Position = UDim2.new(math.random(5, 95)/100, 0, 1.1, 0) -- เกิดใต้จอเล็กน้อย
        bubble.BackgroundColor3 = Color3.fromRGB(160, 100, 255)
        bubble.BackgroundTransparency = math.random(60, 80) / 100
        bubble.BorderSizePixel = 0
        bubble.ZIndex = 2 -- อยู่ระหว่างพื้นหลังกับตัวอักษร
        bubble.Parent = Background
        
        local bCorner = Instance.new("UICorner")
        bCorner.CornerRadius = UDim.new(1, 0)
        bCorner.Parent = bubble
        
        local floatTime = math.random(35, 55) / 10
        local targetPos = UDim2.new(bubble.Position.X.Scale + (math.random(-5, 5)/100), 0, -0.1, 0)
        
        local floatTween = TweenService:Create(bubble, TweenInfo.new(floatTime, Enum.EasingStyle.QuadOut), {
            Position = targetPos,
            BackgroundTransparency = 1
        })
        floatTween:Play()
        
        floatTween.Completed:Connect(function()
            bubble:Destroy()
        end)
    end
end)


-- [[ 4. แอนิเมชันนับถอยหลัง 4 วินาที + เอฟเฟกต์เบลอละลายหายไป ]] --

-- แอนิเมชันหลอดวิ่ง 4 วินาที
local barInfo = TweenInfo.new(4, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out)
local barTween = TweenService:Create(BarFill, barInfo, {Size = UDim2.new(1, 0, 1, 0)})
barTween:Play()

-- ตัวเลขเปอร์เซ็นต์วิ่งวิ่งตามจริง
task.spawn(function()
    local startTime = os.clock()
    local duration = 4
    while os.clock() - startTime < duration do
        local progress = (os.clock() - startTime) / duration
        local cubicProgress = 1 - math.pow(1 - progress, 3) -- อิงตามหลอดวิ่ง
        if cubicProgress > 1 then cubicProgress = 1 end
        
        PercentText.Text = math.floor(cubicProgress * 100) .. "%"
        task.wait()
    end
    PercentText.Text = "100%"
end)

-- เมื่อโหลดเสร็จ (ครบ 4 วินาที)
barTween.Completed:Connect(function()
    isSpawningBubbles = false -- หยุดสร้างฟองเพิ่ม
    
    -- สร้าง Blur ตอนจบใน Lighting
    local blurEffect = Instance.new("BlurEffect")
    blurEffect.Size = 0
    blurEffect.Parent = Lighting
    
    local fadeInfo = TweenInfo.new(0.6, Enum.EasingStyle.QuadOut)
    
    -- ทำการ Fade ลบข้อความและหลอดออกแบบสมูท
    TweenService:Create(Title, fadeInfo, {TextTransparency = 1, TextSize = 35}):Play()
    TweenService:Create(PercentText, fadeInfo, {TextTransparency = 1}):Play()
    TweenService:Create(BarBackground, fadeInfo, {BackgroundTransparency = 1}):Play()
    TweenService:Create(BarFill, fadeInfo, {BackgroundTransparency = 1}):Play()
    
    -- ดึงฉากในเกมให้เบลอขึ้นมา (เอฟเฟกต์ SG)
    TweenService:Create(blurEffect, fadeInfo, {Size = 20}):Play()
    
    task.wait(0.5) -- รอเอฟเฟกต์ตัวหนังสือละลายเสร็จ
    
    -- แอนิเมชันฉากหลังม่วงค่อยๆ จางออก เผยให้เห็นตัวเกม
    local bgFade = TweenService:Create(Background, TweenInfo.new(0.8, Enum.EasingStyle.QuadIn), {BackgroundTransparency = 1})
    bgFade:Play()
    
    -- ค่อยๆ ลดความเบลอในเกมลงจนปกติ
    TweenService:Create(blurEffect, TweenInfo.new(0.8, Enum.EasingStyle.QuadIn), {Size = 0}):Play()
    
    bgFade.Completed:Connect(function()
        blurEffect:Destroy()
        LoadingScreen:Destroy() -- เคลียร์สคริปต์ออกจากเครื่อง
    end)
end)
