-- ฟังชันอัปเดตจอภาพ
local function updateMonitor(statusText, detectedItem)
    MonitorLabel.Text = string.format("【 สถานะระบบ 】\n%s\nจำนวนทำงานรวม: %d ครั้ง\nไอเทมที่สแกน: %s", statusText, totalFired, detectedItem or "ไม่ได้สแกน")
end

