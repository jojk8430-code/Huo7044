    TweenService:Create(BarFill, TweenInfo.new(0.3, Enum.EasingStyle.QuadIn), {BackgroundTransparency = 1}):Play()
    
    task.wait(0.5)
    LoadFrame:Destroy() -- ลบทิ้งทันทีระบบจะได้ไม่หนัก
    MainFrame.Visible = true -- เปิดหน้าต่างโปรแกรมโกงขึ้นมา
end)

-- 2. ฟังก์ชันระบบซื้อไอเทม (Buy)
BuyBtn.MouseButton1Click:Connect(function()
    if buyRunning then
        buyRunning = false
        BuyBtn.Text = "ซื้อ (Loop)"
        BuyBtn.BackgroundColor3 = Color3.fromRGB(0, 140, 90)
        return
    end
    if BuyBox.Text == "" then return end
    buyRunning = true
    BuyBtn.Text = "🔴 หยุดซื้อ"
    BuyBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    
    task.spawn(function()
        local remote = ReplicatedStorage:WaitForChild("RemoteEvents"):WaitForChild("BuyItemCash")
        while buyRunning do
            remote:FireServer(unpack({BuyBox.Text}))
            totalFired = totalFired + 1
            updateMonitor("กำลังซื้อ: " .. BuyBox.Text, BuyBox.Text)
            task.wait(tonumber(DelayBox.Text) or 0.1)
        end
    end)
end)

