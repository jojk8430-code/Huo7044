-- 3. อนิเมชั่น หมุนรอบตัวเอง + ลอยขึ้นลง + สลับสีรุ้ง (Chroma Phase Loop)
task.spawn(function()
local spinTime = 0
local duration = 200 -- แสดงผลเป็นเวลาประมาณ 10 วินาทีแล้วจางหายไป
for i = 1, duration do
if not VisualPart or not BaseRing then break end
spinTime = spinTime + 0.05
local hue = (tick() % 2) / 2 -- วงรอบสลับสีรุ้งเร็วขึ้น 2 วินาที
local rainbowColor = Color3.fromHSV(hue, 1, 1)
-- อัปเดตสี
