-- ฟังก์ชันสำหรับย้ายเซิร์ฟเวอร์อัตโนมัติ (Server Hop)
local function serverHop()
    TimerLabel.Text = "⏳ กำลังค้นหาเซิร์ฟเวอร์ใหม่เพื่อไปฟาร์มต่อ..."
    TimerLabel.TextColor3 = Color3.fromRGB(230, 126, 34)
    task.wait(1)
    
    local x = pcall(function()
        local servers = {}
        local req = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"))
        for _, v in pairs(req.data) do
            if v.playing < v.maxPlayers and v.id ~= game.JobId then
                table.insert(servers, v.id)
            end
        end
        if #servers > 0 then
            TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)], LocalPlayer)
        else
            -- ถ้าหาเซิร์ฟเวอร์ไม่เจอ ให้รีเซ็ตเทเลพอร์ตธรรมดา
            TeleportService:Teleport(game.PlaceId, LocalPlayer)
        end
    end)
    
    if not x then
        TeleportService:Teleport(game.PlaceId, LocalPlayer)
    end
end

-- ฟังก์ชันดึงชื่อเพลง
local function getSongName(assetId)
    local success, info = pcall(function()
        return MarketplaceService:GetProductInfo(assetId, Enum.InfoType.Asset)
    end)
    if success and info then return info.Name else return "Unknown Song / ลิขสิทธิ์" end
end

-- ฟังก์ชันส่งข้อมูลเข้า Discord Webhook
local function sendToDiscord(songName, songId)
    if DISCORD_WEBHOOK_URL == "YOUR_DISCORD_WEBHOOK_URL_HERE" or DISCORD_WEBHOOK_URL == "" then return end
    
    local mapName = "Unknown Map"
    pcall(function() mapName = MarketplaceService:GetProductInfo(game.PlaceId).Name end)

    local data = {
        ["embeds"] = {{
            ["title"] = "🤖 [ระบบฟาร์ม ID] เจอเพลงใหม่จากผู้เล่นคนอื่น!",
            ["color"] = 3447003, -- สีน้ำเงินเข้มขรึม
            ["fields"] = {
                {["name"] = "📝 ชื่อเพลง", ["value"] = "```" .. songName .. "
```", ["inline"] = false},
                {["name"] = "🆔 ID เพลง", ["value"] = "```" .. tostring(songId) .. "```", ["inline"] = true},
                {["name"] = "📌 คัดลอกลิงก์", ["value"] = "[ลิงก์ Roblox](https://www.roblox.com/library/" .. tostring(songId) .. ")", ["inline"] = true},
                {["name"] = "🎮 ฟาร์มจากแมพ", ["value"] = "```" .. mapName .. "
```", ["inline"] = false}
            },
            ["footer"] = {["text"] = "บอท: " .. LocalPlayer.Name .. " | เวลา: " .. os.date("%X")}
        }}
    }
    
    local request = syn and syn.request or http_request or request or HttpService.Request
    if request then
        request({
            Url = DISCORD_WEBHOOK_URL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end
end

