--- 2. ระบบดึงชื่อเพลงและตรวจสอบ ID
local function getSongName(assetId)
    local success, info = pcall(function()
        return MarketplaceService:GetProductInfo(assetId, Enum.InfoType.Asset)
    end)
    if success and info then
        return info.Name
    else
        return "Unknown Song / ติดลิขสิทธิ์"
    end
end

-- ฟังก์ชันสร้างแถบรายชื่อเพลงในหน้าต่าง UI
local function createSongItem(name, id)
    local ItemFrame = Instance.new("Frame")
    ItemFrame.Size = UDim2.new(1, -10, 0, 50)
    ItemFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
    ItemFrame.BorderSizePixel = 0
    
    local ItemCorner = Instance.new("UICorner")
    ItemCorner.CornerRadius = UDim.new(0, 5)
    ItemCorner.Parent = ItemFrame
    
    -- ข้อความแสดงชื่อเพลงและ ID
    local SongText = Instance.new("TextLabel")
    SongText.Size = UDim2.new(0.7, 0, 1, 0)
    SongText.Position = UDim2.new(0, 10, 0, 0)
    SongText.BackgroundTransparency = 1
    SongText.Text = "🎵 " .. name .. "\nID: " .. id
    SongText.TextColor3 = Color3.fromRGB(230, 230, 230)
    SongText.TextSize = 12
    SongText.TextXAlignment = Enum.TextXAlignment.Left
    SongText.Font = Enum.Font.SourceSans
    SongText.Parent = ItemFrame
    
    -- ปุ่มกดคัดลอก (Copy Button)
    local CopyBtn = Instance.new("TextButton")
    CopyBtn.Size = UDim2.new(0.25, 0, 0.7, 0)
    CopyBtn.Position = UDim2.new(0.72, 0, 0.15, 0)
    CopyBtn.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
    CopyBtn.Text = "Copy ID"
    CopyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    CopyBtn.TextSize = 12
    CopyBtn.Font = Enum.Font.SourceSansBold
    CopyBtn.Parent = ItemFrame
    
    local CopyCorner = Instance.new("UICorner")
    CopyCorner.CornerRadius = UDim.new(0, 5)
    CopyCorner.Parent = CopyBtn
    
    -- เมื่อกดปุ่มจะ Copy ลง Clipboard ของผู้เล่นทันที
    CopyBtn.MouseButton1Click:Connect(function()
        if setclipboard then
            setclipboard(tostring(id))
            CopyBtn.Text = "Copied! ✔"
            CopyBtn.BackgroundColor3 = Color3.fromRGB(39, 174, 96)
            task.wait(1.5)
            CopyBtn.Text = "Copy ID"
            CopyBtn.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
        else
            CopyBtn.Text = "No Clipboard Support"
            CopyBtn.BackgroundColor3 = Color3.fromRGB(192, 41, 43)
        end
    end)
    
    ItemFrame.Parent = ScrollContainer
    ScrollContainer.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y)
end

--- 3. ฟังก์ชันสแกนหาเพลงในเกม
ScanButton.MouseButton1Click:Connect(function()
    -- ล้างข้อมูลเก่าในหน้าต่างออกก่อนสแกนใหม่
    for _, child in pairs(ScrollContainer:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    ScanButton.Text = "⏳ กำลังสแกนหาเพลง..."
    ScanButton.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    task.wait(0.5) -- หน่วงเวลานิดหน่อยให้สมจริง
    
    local foundSongs = {}
    local totalFound = 0
    
    -- ค้นหาไฟล์ Sound ทั้งหมดในทุกมุมของเซิร์ฟเวอร์ (Workspace, SoundService ฯลฯ)
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("Sound") and v.IsPlaying and v.Volume > 0 then
            local rawId = string.match(v.SoundId, "%d+")
            if rawId then
                local songId = tonumber(rawId)
                -- ตรวจสอบไม่ให้ชื่อซ้ำกันในการสแกนรอบนั้นๆ
                if not foundSongs[songId] then
                    foundSongs[songId] = true
                    totalFound = totalFound + 1
                    
                    local songName = getSongName(songId)
                    createSongItem(songName, songId)
                end
            end
        end
    end
    
    -- อัปเดตข้อความบนปุ่มหลังจากสแกนเสร็จ
    if totalFound > 0 then
        ScanButton.Text = "✔ เจอทั้งหมด " .. totalFound .. " เพลง! (กดสแกนใหม่ได้)"
        ScanButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
    else
        ScanButton.Text = "❌ ไม่พบเพลงที่เปิดอยู่ ลองใหม่อีกครั้ง"
        ScanButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
    end
    
    task.wait(2)
    ScanButton.Text = "🔍 กดเพื่อดูดเพลงในแมพ"
    ScanButton.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
end)
