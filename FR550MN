-- ลูปสแกนและจับเวลาหลัก
task.spawn(function()
    while true do
        -- สแกนหาเพลงในเซิร์ฟเวอร์ปัจจุบัน
        for _, v in pairs(game:GetDescendants()) do
            if v:IsA("Sound") and v.IsPlaying and v.Volume > 0 then
                local rawId = string.match(v.SoundId, "%d+")
                if rawId then
                    local songId = tonumber(rawId)
                    
                    -- ตรวจสอบว่าไม่เคยสแกนเจอมาก่อนเลยในประวัติการฟาร์ม
                    if not LoggedSongs[tostring(songId)] then
                        LoggedSongs[tostring(songId)] = true
                        
                        -- บันทึกเก็บลงไฟล์ในเครื่องคอมพิวเตอร์เพื่อกันลืมตอนย้ายเซิร์ฟเวอร์
                        if writefile then
                            writefile(filename, HttpService:JSONEncode(LoggedSongs))
                        end
                        
                        local songName = getSongName(songId)
                        createSongItem(songName, songId)
                        sendToDiscord(songName, songId)
                    end
                end
            end
        end
        
        -- จัดการเรื่องนับเวลาการฟาร์มข้ามแมพ
        if isFarming then
            if farmTimer > 0 then
                TimerLabel.Text = "🕒 กำลังดูด ID เพลงในเซิร์ฟนี้... จะย้ายเซิร์ฟเวอร์ในอีก " .. farmTimer .. " วินาที"
                TimerLabel.TextColor3 = Color3.fromRGB(52, 152, 219)
                farmTimer = farmTimer - 1
            else
                isFarming = false
                serverHop()
            end
        end
        
        task.wait(1)
    end
end)
